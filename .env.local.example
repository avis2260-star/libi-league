# Copy this file to .env.local and fill in your Supabase project credentials.
# Find these in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service role key — SERVER ONLY. Never expose to the browser.
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Comma-separated list of email addresses allowed to access /admin
ADMIN_EMAILS=you@example.com
